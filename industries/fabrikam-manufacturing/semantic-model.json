    "measures": [
      {"name": "Total Units Produced", "table": "FactProductionOrders", "expression": "SUM(FactProductionOrders[QuantityProduced])", "formatString": "#,0", "displayFolder": "Production"},
      {"name": "Total Units Ordered", "table": "FactProductionOrders", "expression": "SUM(FactProductionOrders[QuantityOrdered])", "formatString": "#,0", "displayFolder": "Production"},
      {"name": "Total Scrap Units", "table": "FactProductionOrders", "expression": "SUM(FactProductionOrders[QuantityScrapped])", "formatString": "#,0", "displayFolder": "Production"},
      {"name": "Schedule Adherence %", "table": "FactProductionOrders", "expression": "DIVIDE(SUM(FactProductionOrders[QuantityProduced]), SUM(FactProductionOrders[QuantityOrdered]))", "formatString": "0.0%", "displayFolder": "Production"},
      {"name": "Avg Cycle Time (min)", "table": "FactProductionOrders", "expression": "AVERAGE(FactProductionOrders[CycleTimeMinutes])", "formatString": "#,0.0", "displayFolder": "Production"},
      {"name": "Total Good Units", "table": "FactProductionOutput", "expression": "SUM(FactProductionOutput[GoodUnits])", "formatString": "#,0", "displayFolder": "Production"},
      {"name": "Total Defect Units", "table": "FactProductionOutput", "expression": "SUM(FactProductionOutput[DefectUnits])", "formatString": "#,0", "displayFolder": "Production"},
      {"name": "First Pass Yield %", "table": "FactProductionOutput", "expression": "DIVIDE(SUM(FactProductionOutput[GoodUnits]), SUM(FactProductionOutput[GoodUnits]) + SUM(FactProductionOutput[DefectUnits]))", "formatString": "0.0%", "displayFolder": "Production"},
      {"name": "OEE Availability", "table": "FactProductionOutput", "expression": "DIVIDE(SUM(FactProductionOutput[ActualRunTimeMinutes]), SUM(FactProductionOutput[PlannedRunTimeMinutes]))", "formatString": "0.0%", "displayFolder": "OEE"},
      {"name": "OEE Performance", "table": "FactProductionOutput", "expression": "DIVIDE(SUM(FactProductionOutput[GoodUnits]) + SUM(FactProductionOutput[DefectUnits]), SUM(FactProductionOutput[ActualRunTimeMinutes]) * 10)", "formatString": "0.0%", "displayFolder": "OEE"},
      {"name": "OEE Quality", "table": "FactProductionOutput", "expression": "DIVIDE(SUM(FactProductionOutput[GoodUnits]), SUM(FactProductionOutput[GoodUnits]) + SUM(FactProductionOutput[DefectUnits]))", "formatString": "0.0%", "displayFolder": "OEE"},
      {"name": "OEE Overall", "table": "FactProductionOutput", "expression": "[OEE Availability] * [OEE Performance] * [OEE Quality]", "formatString": "0.0%", "displayFolder": "OEE"},
      {"name": "Total Downtime (hrs)", "table": "FactProductionOutput", "expression": "DIVIDE(SUM(FactProductionOutput[DowntimeMinutes]), 60)", "formatString": "#,0.0", "displayFolder": "OEE"},
      {"name": "Total Inspections", "table": "FactQualityInspections", "expression": "COUNTROWS(FactQualityInspections)", "formatString": "#,0", "displayFolder": "Quality"},
      {"name": "Total Defects Found", "table": "FactQualityInspections", "expression": "SUM(FactQualityInspections[DefectsFound])", "formatString": "#,0", "displayFolder": "Quality"},
      {"name": "Inspection Pass Rate %", "table": "FactQualityInspections", "expression": "DIVIDE(CALCULATE(COUNTROWS(FactQualityInspections), FactQualityInspections[Result] = \"Pass\"), COUNTROWS(FactQualityInspections))", "formatString": "0.0%", "displayFolder": "Quality"},
      {"name": "DPPM", "table": "FactQualityInspections", "expression": "DIVIDE(SUM(FactQualityInspections[DefectsFound]), SUM(FactQualityInspections[SampleSize])) * 1000000", "formatString": "#,0", "displayFolder": "Quality"},
      {"name": "Total NCRs", "table": "FactNonConformance", "expression": "COUNTROWS(FactNonConformance)", "formatString": "#,0", "displayFolder": "Quality"},
      {"name": "Cost of Quality", "table": "FactNonConformance", "expression": "SUM(FactNonConformance[CostOfQuality])", "formatString": "$#,0;($#,0)", "displayFolder": "Quality"},
      {"name": "NCR Qty Affected", "table": "FactNonConformance", "expression": "SUM(FactNonConformance[QuantityAffected])", "formatString": "#,0", "displayFolder": "Quality"},
      {"name": "Total PO Value", "table": "FactPurchaseOrders", "expression": "SUM(FactPurchaseOrders[TotalCost])", "formatString": "$#,0;($#,0)", "displayFolder": "Supply Chain"},
      {"name": "Total POs", "table": "FactPurchaseOrders", "expression": "COUNTROWS(FactPurchaseOrders)", "formatString": "#,0", "displayFolder": "Supply Chain"},
      {"name": "On-Time Delivery %", "table": "FactGoodsReceipt", "expression": "DIVIDE(CALCULATE(COUNTROWS(FactGoodsReceipt), FactGoodsReceipt[DaysLateOrEarly] <= 0), COUNTROWS(FactGoodsReceipt))", "formatString": "0.0%", "displayFolder": "Supply Chain"},
      {"name": "Avg Days Late", "table": "FactGoodsReceipt", "expression": "AVERAGE(FactGoodsReceipt[DaysLateOrEarly])", "formatString": "#,0.0", "displayFolder": "Supply Chain"},
      {"name": "Goods Receipt Accept Rate", "table": "FactGoodsReceipt", "expression": "DIVIDE(CALCULATE(COUNTROWS(FactGoodsReceipt), FactGoodsReceipt[QualityCheckResult] = \"Accepted\"), COUNTROWS(FactGoodsReceipt))", "formatString": "0.0%", "displayFolder": "Supply Chain"},
      {"name": "Total Inventory Value", "table": "FactInventory", "expression": "SUM(FactInventory[InventoryValue])", "formatString": "$#,0;($#,0)", "displayFolder": "Supply Chain"},
      {"name": "Avg Inventory On Hand", "table": "FactInventory", "expression": "AVERAGE(FactInventory[QuantityOnHand])", "formatString": "#,0", "displayFolder": "Supply Chain"},
      {"name": "Total Maintenance WOs", "table": "FactMaintenanceWorkOrders", "expression": "COUNTROWS(FactMaintenanceWorkOrders)", "formatString": "#,0", "displayFolder": "Maintenance"},
      {"name": "Total Maintenance Cost", "table": "FactMaintenanceWorkOrders", "expression": "SUM(FactMaintenanceWorkOrders[PartsCost]) + SUM(FactMaintenanceWorkOrders[LaborCost])", "formatString": "$#,0;($#,0)", "displayFolder": "Maintenance"},
      {"name": "Avg Labor Hours", "table": "FactMaintenanceWorkOrders", "expression": "AVERAGE(FactMaintenanceWorkOrders[LaborHours])", "formatString": "#,0.0", "displayFolder": "Maintenance"},
      {"name": "PM Compliance %", "table": "FactMaintenanceWorkOrders", "expression": "DIVIDE(CALCULATE(COUNTROWS(FactMaintenanceWorkOrders), FactMaintenanceWorkOrders[Status] = \"Completed\"), COUNTROWS(FactMaintenanceWorkOrders))", "formatString": "0.0%", "displayFolder": "Maintenance"},
      {"name": "Downtime Events", "table": "FactDowntime", "expression": "COUNTROWS(FactDowntime)", "formatString": "#,0", "displayFolder": "Maintenance"},
      {"name": "Total Downtime Hrs", "table": "FactDowntime", "expression": "DIVIDE(SUM(FactDowntime[DurationMinutes]), 60)", "formatString": "#,0.0", "displayFolder": "Maintenance"},
      {"name": "Avg Downtime Duration (min)", "table": "FactDowntime", "expression": "AVERAGE(FactDowntime[DurationMinutes])", "formatString": "#,0", "displayFolder": "Maintenance"},
      {"name": "Unplanned Downtime %", "table": "FactDowntime", "expression": "DIVIDE(CALCULATE(SUM(FactDowntime[DurationMinutes]), FactDowntime[IsUnplanned] = TRUE()), SUM(FactDowntime[DurationMinutes]))", "formatString": "0.0%", "displayFolder": "Maintenance"},
      {"name": "Total Safety Incidents", "table": "FactSafetyIncidents", "expression": "COUNTROWS(FactSafetyIncidents)", "formatString": "#,0", "displayFolder": "EHS"},
      {"name": "Lost Time Days", "table": "FactSafetyIncidents", "expression": "SUM(FactSafetyIncidents[LostTimeDays])", "formatString": "#,0", "displayFolder": "EHS"},
      {"name": "Safety Cost", "table": "FactSafetyIncidents", "expression": "SUM(FactSafetyIncidents[CostUSD])", "formatString": "$#,0;($#,0)", "displayFolder": "EHS"},
      {"name": "Near Miss Ratio", "table": "FactSafetyIncidents", "expression": "DIVIDE(CALCULATE(COUNTROWS(FactSafetyIncidents), FactSafetyIncidents[IncidentType] = \"Near Miss\"), COUNTROWS(FactSafetyIncidents))", "formatString": "0.0%", "displayFolder": "EHS"},
      {"name": "Environmental Compliance %", "table": "FactEnvironmentalReadings", "expression": "DIVIDE(CALCULATE(COUNTROWS(FactEnvironmentalReadings), FactEnvironmentalReadings[IsCompliant] = TRUE()), COUNTROWS(FactEnvironmentalReadings))", "formatString": "0.0%", "displayFolder": "EHS"},
      {"name": "Total Environmental Readings", "table": "FactEnvironmentalReadings", "expression": "COUNTROWS(FactEnvironmentalReadings)", "formatString": "#,0", "displayFolder": "EHS"}
    ]
  }
}
