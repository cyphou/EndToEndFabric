{
  "webEnrichment": {
    "enabled": true,
    "targetLakehouse": "SilverLH",
    "schema": "web",
    "sources": [
      {
        "name": "ExchangeRates",
        "description": "Daily USD exchange rates for energy trading",
        "endpoint": "https://api.exchangerate.host/latest?base=USD",
        "method": "GET",
        "schedule": "daily",
        "tableName": "WebExchangeRates",
        "columns": [
          {
            "name": "BaseCurrency",
            "type": "string"
          },
          {
            "name": "TargetCurrency",
            "type": "string"
          },
          {
            "name": "Rate",
            "type": "double"
          },
          {
            "name": "AsOfDate",
            "type": "date"
          }
        ]
      },
      {
        "name": "WeatherForecast",
        "description": "7-day weather forecast for plant locations",
        "endpoint": "https://api.open-meteo.com/v1/forecast",
        "method": "GET",
        "schedule": "daily",
        "tableName": "WebWeatherForecast",
        "columns": [
          {
            "name": "Latitude",
            "type": "double"
          },
          {
            "name": "Longitude",
            "type": "double"
          },
          {
            "name": "ForecastDate",
            "type": "date"
          },
          {
            "name": "TemperatureMax",
            "type": "double"
          },
          {
            "name": "TemperatureMin",
            "type": "double"
          },
          {
            "name": "WindSpeed",
            "type": "double"
          },
          {
            "name": "SolarRadiation",
            "type": "double"
          }
        ]
      },
      {
        "name": "EnergyPrices",
        "description": "Daily wholesale energy prices by region",
        "endpoint": "https://api.eia.gov/v2/electricity/rto",
        "method": "GET",
        "schedule": "daily",
        "tableName": "WebEnergyPrices",
        "columns": [
          {
            "name": "Region",
            "type": "string"
          },
          {
            "name": "PriceDate",
            "type": "date"
          },
          {
            "name": "PricePerMWh",
            "type": "double"
          },
          {
            "name": "PeakPrice",
            "type": "double"
          },
          {
            "name": "OffPeakPrice",
            "type": "double"
          }
        ]
      },
      {
        "name": "CarbonIntensity",
        "description": "Grid carbon intensity by region",
        "endpoint": "https://api.carbonintensity.org.uk/intensity",
        "method": "GET",
        "schedule": "daily",
        "tableName": "WebCarbonIntensity",
        "columns": [
          {
            "name": "Region",
            "type": "string"
          },
          {
            "name": "IntensityDate",
            "type": "date"
          },
          {
            "name": "Forecast",
            "type": "double"
          },
          {
            "name": "Actual",
            "type": "double"
          },
          {
            "name": "Index",
            "type": "string"
          }
        ]
      }
    ]
  }
}
