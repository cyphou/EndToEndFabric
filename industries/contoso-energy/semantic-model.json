    "measures": [
      {
        "name": "Total Generation MWh",
        "table": "FactGeneration",
        "expression": "SUM(FactGeneration[MWhGenerated])",
        "formatString": "#,0.0",
        "displayFolder": "Generation"
      },
      {
        "name": "Avg Plant Efficiency",
        "table": "FactGeneration",
        "expression": "AVERAGE(FactGeneration[Efficiency])",
        "formatString": "0.0%",
        "displayFolder": "Generation"
      },
      {
        "name": "Total CO2 Emissions",
        "table": "FactGeneration",
        "expression": "SUM(FactGeneration[CO2EmissionsTons])",
        "formatString": "#,0",
        "displayFolder": "Generation"
      },
      {
        "name": "Renewable Generation %",
        "table": "FactGeneration",
        "expression": "DIVIDE(CALCULATE(SUM(FactGeneration[MWhGenerated]), DimPowerPlants[IsRenewable] = TRUE()), SUM(FactGeneration[MWhGenerated]))",
        "formatString": "0.0%",
        "displayFolder": "Generation"
      },
      {
        "name": "Peak Load MW",
        "table": "FactGridLoad",
        "expression": "MAX(FactGridLoad[LoadMW])",
        "formatString": "#,0.0",
        "displayFolder": "Grid Operations"
      },
      {
        "name": "Avg Load MW",
        "table": "FactGridLoad",
        "expression": "AVERAGE(FactGridLoad[LoadMW])",
        "formatString": "#,0.0",
        "displayFolder": "Grid Operations"
      },
      {
        "name": "Total Outages",
        "table": "FactOutages",
        "expression": "COUNTROWS(FactOutages)",
        "formatString": "#,0",
        "displayFolder": "Grid Operations"
      },
      {
        "name": "Avg Outage Duration (min)",
        "table": "FactOutages",
        "expression": "AVERAGE(FactOutages[DurationMinutes])",
        "formatString": "#,0",
        "displayFolder": "Grid Operations"
      },
      {
        "name": "Total Customers Affected",
        "table": "FactOutages",
        "expression": "SUM(FactOutages[AffectedCustomers])",
        "formatString": "#,0",
        "displayFolder": "Grid Operations"
      },
      {
        "name": "Total Revenue",
        "table": "FactBilling",
        "expression": "SUM(FactBilling[AmountBilled])",
        "formatString": "$#,0;($#,0)",
        "displayFolder": "Billing"
      },
      {
        "name": "Total KWh Consumed",
        "table": "FactBilling",
        "expression": "SUM(FactBilling[KWhConsumed])",
        "formatString": "#,0",
        "displayFolder": "Billing"
      },
      {
        "name": "Avg Bill Amount",
        "table": "FactBilling",
        "expression": "AVERAGE(FactBilling[AmountBilled])",
        "formatString": "$#,0.00",
        "displayFolder": "Billing"
      },
      {
        "name": "Payment Collection Rate",
        "table": "FactBilling",
        "expression": "DIVIDE(CALCULATE(COUNTROWS(FactBilling), FactBilling[PaymentStatus] = \"Paid\"), COUNTROWS(FactBilling))",
        "formatString": "0.0%",
        "displayFolder": "Billing"
      },
      {
        "name": "Total CO2e Tons",
        "table": "FactEmissions",
