          { "name": "SnapshotDate", "dataType": "DateTime" },
          { "name": "QuantityOnHand", "dataType": "Int64" },
          { "name": "ReorderPoint", "dataType": "Int64" }
        ]
      },
      {
        "name": "FactReturns", "schema": "fact", "tableType": "fact",
        "columns": [
          { "name": "ReturnID", "dataType": "Int64", "isKey": true },
