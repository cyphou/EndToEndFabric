          { "name": "OrderDate", "dataType": "DateTime" },
          { "name": "Quantity", "dataType": "Int64" },
          { "name": "UnitPrice", "dataType": "Decimal", "formatString": "$#,##0.00" },
          { "name": "Channel", "dataType": "String" }
        ]
      },
      {
        "name": "FactInventory", "schema": "fact", "tableType": "fact",
        "columns": [
          { "name": "InventoryID", "dataType": "Int64", "isKey": true },
          { "name": "BookID", "dataType": "Int64" },
