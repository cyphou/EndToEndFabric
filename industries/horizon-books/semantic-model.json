          { "name": "ReturnDate", "dataType": "DateTime" },
          { "name": "Quantity", "dataType": "Int64" },
          { "name": "Reason", "dataType": "String" }
        ]
      },
      {
        "name": "FactPayroll", "schema": "fact", "tableType": "fact",
        "columns": [
          { "name": "PayrollID", "dataType": "Int64", "isKey": true },
          { "name": "EmployeeID", "dataType": "Int64" },
          { "name": "PayPeriodMonth", "dataType": "DateTime" },
          { "name": "GrossPay", "dataType": "Decimal", "formatString": "$#,##0.00" },
          { "name": "NetPay", "dataType": "Decimal", "formatString": "$#,##0.00" },
          { "name": "Deductions", "dataType": "Decimal", "formatString": "$#,##0.00" }
        ]
      },
      {
        "name": "FactPerformanceReviews", "schema": "fact", "tableType": "fact",
        "columns": [
          { "name": "ReviewID", "dataType": "Int64", "isKey": true },
          { "name": "EmployeeID", "dataType": "Int64" },
          { "name": "ReviewDate", "dataType": "DateTime" },
          { "name": "Rating", "dataType": "Int64" },
          { "name": "ReviewerComments", "dataType": "String" }
        ]
      },
      {
        "name": "FactRecruitment", "schema": "fact", "tableType": "fact",
        "columns": [
          { "name": "RecruitmentID", "dataType": "Int64", "isKey": true },
          { "name": "DepartmentID", "dataType": "Int64" },
          { "name": "PositionTitle", "dataType": "String" },
          { "name": "PostingDate", "dataType": "DateTime" },
          { "name": "Status", "dataType": "String" },
          { "name": "CandidateName", "dataType": "String" }
        ]
      }
    ],
    "relationships": [
      { "fromTable": "FactFinancialTransactions", "fromColumn": "AccountID", "toTable": "DimAccounts", "toColumn": "AccountID" },
      { "fromTable": "FactFinancialTransactions", "fromColumn": "CostCenterID", "toTable": "DimCostCenters", "toColumn": "CostCenterID" },
      { "fromTable": "FactBudget", "fromColumn": "AccountID", "toTable": "DimAccounts", "toColumn": "AccountID" },
      { "fromTable": "FactBudget", "fromColumn": "CostCenterID", "toTable": "DimCostCenters", "toColumn": "CostCenterID" },
      { "fromTable": "FactOrders", "fromColumn": "BookID", "toTable": "DimBooks", "toColumn": "BookID" },
      { "fromTable": "FactOrders", "fromColumn": "CustomerID", "toTable": "DimCustomers", "toColumn": "CustomerID" },
      { "fromTable": "FactInventory", "fromColumn": "BookID", "toTable": "DimBooks", "toColumn": "BookID" },
      { "fromTable": "FactInventory", "fromColumn": "WarehouseID", "toTable": "DimWarehouses", "toColumn": "WarehouseID" },
      { "fromTable": "FactReturns", "fromColumn": "OrderID", "toTable": "FactOrders", "toColumn": "OrderID" },
      { "fromTable": "FactPayroll", "fromColumn": "EmployeeID", "toTable": "DimEmployees", "toColumn": "EmployeeID" },
      { "fromTable": "FactPerformanceReviews", "fromColumn": "EmployeeID", "toTable": "DimEmployees", "toColumn": "EmployeeID" },
      { "fromTable": "FactRecruitment", "fromColumn": "DepartmentID", "toTable": "DimDepartments", "toColumn": "DepartmentID" },
      { "fromTable": "DimEmployees", "fromColumn": "DepartmentID", "toTable": "DimDepartments", "toColumn": "DepartmentID" },
      { "fromTable": "DimBooks", "fromColumn": "AuthorID", "toTable": "DimAuthors", "toColumn": "AuthorID" }
    ],
    "measures": [
      { "name": "Total Revenue", "table": "FactFinancialTransactions", "expression": "CALCULATE(SUM(FactFinancialTransactions[Amount]), DimAccounts[AccountType] = \"Revenue\")", "formatString": "$#,##0", "displayFolder": "Finance" },
      { "name": "Total COGS", "table": "FactFinancialTransactions", "expression": "CALCULATE(SUM(FactFinancialTransactions[Amount]), DimAccounts[AccountType] = \"COGS\")", "formatString": "$#,##0", "displayFolder": "Finance" },
      { "name": "Gross Profit", "table": "FactFinancialTransactions", "expression": "[Total Revenue] - [Total COGS]", "formatString": "$#,##0", "displayFolder": "Finance" },
      { "name": "Operating Expenses", "table": "FactFinancialTransactions", "expression": "CALCULATE(SUM(FactFinancialTransactions[Amount]), DimAccounts[AccountType] = \"OpEx\")", "formatString": "$#,##0", "displayFolder": "Finance" },
      { "name": "Operating Margin %", "table": "FactFinancialTransactions", "expression": "DIVIDE([Gross Profit] - [Operating Expenses], [Total Revenue], 0)", "formatString": "0.0%", "displayFolder": "Finance" },
      { "name": "Budget Amount", "table": "FactBudget", "expression": "SUM(FactBudget[BudgetAmount])", "formatString": "$#,##0", "displayFolder": "Finance" },
      { "name": "Budget Variance", "table": "FactBudget", "expression": "[Total Revenue] - [Budget Amount]", "formatString": "$#,##0", "displayFolder": "Finance" },
      { "name": "Budget Variance %", "table": "FactBudget", "expression": "DIVIDE([Budget Variance], [Budget Amount], 0)", "formatString": "0.0%", "displayFolder": "Finance" },
      { "name": "Total Orders", "table": "FactOrders", "expression": "COUNTROWS(FactOrders)", "formatString": "#,##0", "displayFolder": "Operations" },
      { "name": "Total Quantity Sold", "table": "FactOrders", "expression": "SUM(FactOrders[Quantity])", "formatString": "#,##0", "displayFolder": "Operations" },
      { "name": "Order Revenue", "table": "FactOrders", "expression": "SUMX(FactOrders, FactOrders[Quantity] * FactOrders[UnitPrice])", "formatString": "$#,##0", "displayFolder": "Operations" },
      { "name": "Average Order Value", "table": "FactOrders", "expression": "DIVIDE([Order Revenue], [Total Orders], 0)", "formatString": "$#,##0.00", "displayFolder": "Operations" },
      { "name": "Total Returns", "table": "FactReturns", "expression": "SUM(FactReturns[Quantity])", "formatString": "#,##0", "displayFolder": "Operations" },
      { "name": "Return Rate %", "table": "FactReturns", "expression": "DIVIDE([Total Returns], [Total Quantity Sold], 0)", "formatString": "0.0%", "displayFolder": "Operations" },
      { "name": "Inventory On Hand", "table": "FactInventory", "expression": "SUM(FactInventory[QuantityOnHand])", "formatString": "#,##0", "displayFolder": "Operations" },
      { "name": "Headcount", "table": "DimEmployees", "expression": "COUNTROWS(DimEmployees)", "formatString": "#,##0", "displayFolder": "HR" },
      { "name": "Total Payroll", "table": "FactPayroll", "expression": "SUM(FactPayroll[GrossPay])", "formatString": "$#,##0", "displayFolder": "HR" },
      { "name": "Avg Salary", "table": "DimEmployees", "expression": "AVERAGE(DimEmployees[Salary])", "formatString": "$#,##0", "displayFolder": "HR" },
      { "name": "Avg Rating", "table": "FactPerformanceReviews", "expression": "AVERAGE(FactPerformanceReviews[Rating])", "formatString": "0.0", "displayFolder": "HR" },
      { "name": "Open Positions", "table": "FactRecruitment", "expression": "CALCULATE(COUNTROWS(FactRecruitment), FactRecruitment[Status] = \"Open\")", "formatString": "#,##0", "displayFolder": "HR" }
    ]
  }
}
