    "measures": [
      {
        "name": "Headcount",
        "table": "DimEmployees",
        "expression": "COUNTROWS(FILTER(DimEmployees, DimEmployees[EmploymentStatus] = \"Active\"))",
        "formatString": "#,0",
        "displayFolder": "HR"
      },
      {
        "name": "New Hires",
        "table": "FactRecruitment",
        "expression": "SUM(FactRecruitment[Hired])",
        "formatString": "#,0",
        "displayFolder": "HR"
      },
      {
        "name": "Avg Time to Fill",
        "table": "FactRecruitment",
        "expression": "AVERAGE(FactRecruitment[TimeToFillDays])",
        "formatString": "#,0",
        "displayFolder": "HR"
      },
      {
        "name": "Offer Accept Rate",
        "table": "FactRecruitment",
        "expression": "DIVIDE(SUM(FactRecruitment[Hired]), SUM(FactRecruitment[Interviewed]))",
        "formatString": "0.0%",
        "displayFolder": "HR"
      },
      {
        "name": "Avg Performance Rating",
        "table": "FactPerformanceReviews",
        "expression": "AVERAGE(FactPerformanceReviews[OverallRating])",
        "formatString": "0.00",
        "displayFolder": "HR"
      },
      {
        "name": "Attrition Count",
        "table": "FactAttrition",
        "expression": "COUNTROWS(FactAttrition)",
        "formatString": "#,0",
        "displayFolder": "HR"
      },
      {
        "name": "Voluntary Attrition %",
        "table": "FactAttrition",
        "expression": "DIVIDE(CALCULATE(COUNTROWS(FactAttrition), FactAttrition[IsVoluntary] = TRUE()), COUNTROWS(FactAttrition))",
        "formatString": "0.0%",
        "displayFolder": "HR"
      },
      {
        "name": "Total Gross Pay",
        "table": "FactPayroll",
        "expression": "SUM(FactPayroll[GrossPay])",
        "formatString": "$#,0;($#,0)",
        "displayFolder": "Payroll"
      },
      {
        "name": "Total Net Pay",
        "table": "FactPayroll",
        "expression": "SUM(FactPayroll[NetPay])",
        "formatString": "$#,0;($#,0)",
        "displayFolder": "Payroll"
      },
      {
        "name": "Total Deductions",
        "table": "FactPayroll",
        "expression": "SUM(FactPayroll[Deductions])",
        "formatString": "$#,0;($#,0)",
        "displayFolder": "Payroll"
      },
      {
        "name": "Avg Salary Per Employee",
        "table": "FactPayroll",
        "expression": "DIVIDE(SUM(FactPayroll[GrossPay]), DISTINCTCOUNT(FactPayroll[EmployeeID]))",
        "formatString": "$#,0",
        "displayFolder": "Payroll"
      },
      {
        "name": "Overtime Hours",
        "table": "FactPayroll",
        "expression": "SUM(FactPayroll[OvertimeHours])",
        "formatString": "#,0.0",
        "displayFolder": "Payroll"
      },
      {
        "name": "Total Benefits Cost",
        "table": "FactBenefits",
        "expression": "SUM(FactBenefits[EmployerCost]) + SUM(FactBenefits[EmployeeCost])",
        "formatString": "$#,0",
        "displayFolder": "Payroll"
      },
      {
        "name": "Total Debits",
        "table": "FactJournalEntries",
        "expression": "SUM(FactJournalEntries[DebitAmount])",
        "formatString": "$#,0;($#,0)",
        "displayFolder": "Finance"
      },
      {
        "name": "Total Credits",
        "table": "FactJournalEntries",
        "expression": "SUM(FactJournalEntries[CreditAmount])",
        "formatString": "$#,0;($#,0)",
        "displayFolder": "Finance"
      },
      {
        "name": "AP Outstanding",
        "table": "FactAccountsPayable",
        "expression": "SUM(FactAccountsPayable[Amount]) - SUM(FactAccountsPayable[PaidAmount])",
        "formatString": "$#,0;($#,0)",
        "displayFolder": "Finance"
      },
      {
        "name": "AR Outstanding",
        "table": "FactAccountsReceivable",
        "expression": "SUM(FactAccountsReceivable[Amount]) - SUM(FactAccountsReceivable[CollectedAmount])",
        "formatString": "$#,0;($#,0)",
        "displayFolder": "Finance"
      },
      {
        "name": "Collection Rate",
        "table": "FactAccountsReceivable",
        "expression": "DIVIDE(SUM(FactAccountsReceivable[CollectedAmount]), SUM(FactAccountsReceivable[Amount]))",
        "formatString": "0.0%",
        "displayFolder": "Finance"
      },
      {
        "name": "Budget Amount",
        "table": "FactBudget",
        "expression": "SUM(FactBudget[BudgetAmount])",
        "formatString": "$#,0;($#,0)",
        "displayFolder": "Budgeting"
      },
      {
        "name": "Actual Spend",
        "table": "FactBudget",
        "expression": "SUM(FactBudget[ActualAmount])",
        "formatString": "$#,0;($#,0)",
        "displayFolder": "Budgeting"
      },
      {
        "name": "Budget Variance",
        "table": "FactBudget",
        "expression": "SUM(FactBudget[BudgetAmount]) - SUM(FactBudget[ActualAmount])",
        "formatString": "$#,0;($#,0)",
        "displayFolder": "Budgeting"
      },
      {
        "name": "Budget Utilization %",
        "table": "FactBudget",
        "expression": "DIVIDE(SUM(FactBudget[ActualAmount]), SUM(FactBudget[BudgetAmount]))",
        "formatString": "0.0%",
        "displayFolder": "Budgeting"
      },
      {
        "name": "Avg KPI Score",
        "table": "FactKPIResults",
        "expression": "AVERAGE(FactKPIResults[Score])",
        "formatString": "0.00",
        "displayFolder": "Performance"
      },
      {
        "name": "KPIs On Target",
        "table": "FactKPIResults",
        "expression": "CALCULATE(COUNTROWS(FactKPIResults), FactKPIResults[ActualValue] >= FactKPIResults[TargetValue])",
        "formatString": "#,0",
        "displayFolder": "Performance"
      }
    ]
  }
}